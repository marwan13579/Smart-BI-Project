    {
      "parameters": {
        "jsCode": "const items = $input.all();\nlet totalRevenue = 0;\nlet productCounts = {};\nlet hourlySales = {};\nlet dailySales = {}; \nlet totalQty = 0;\n\nitems.forEach(item => {\n    const data = item.json;\n    const price = data.Standard_Price || 0;\n    const qty = data.Standard_Qty || 0;\n    const productName = data.Standard_Product || \"غير معروف\";\n    const orderDate = data.Std_Date;\n    const orderHour = data.Std_Hour; // القيمة اللي جاية من عمود الوقت المنفصل\n\n    totalRevenue += price;\n    totalQty += qty;\n    productCounts[productName] = (productCounts[productName] || 0) + qty;\n\n    if (orderDate) {\n        const dateObj = isNaN(orderDate) ? new Date(orderDate) : new Date((orderDate - 25569) * 86400 * 1000);\n        if (!isNaN(dateObj.getTime())) {\n            let hour = dateObj.getHours();\n\n            // لو المستخدم مدخل ساعة في عمود منفصل، نستخدمها هي\n            if (orderHour && orderHour.toString().trim() !== \"\") {\n                const extractHour = parseInt(orderHour.toString().match(/\\d+/));\n                if (!isNaN(extractHour)) hour = extractHour;\n            }\n\n            hourlySales[hour] = (hourlySales[hour] || 0) + 1;\n\n            const dayStr = dateObj.toISOString().split('T')[0];\n            dailySales[dayStr] = (dailySales[dayStr] || 0) + price;\n        }\n    }\n});\n\nconst peakHourEntries = Object.entries(hourlySales).sort((a, b) => b[1] - a[1]);\nconst bestDayEntries = Object.entries(dailySales).sort((a, b) => b[1] - a[1]);\n\nlet peakResult = \"غير محدد\";\n\nif (peakHourEntries.length > 0) {\n    const topHour = peakHourEntries[0][0];\n    // لو مفيش غير الساعة 0 (يعني الملف تاريخ بس ومفيهوش عمود وقت)\n    if (topHour === \"0\" && peakHourEntries.length === 1) {\n        if (bestDayEntries.length > 0) {\n            peakResult = \"يوم: \" + bestDayEntries[0][0];\n        }\n    } else {\n        peakResult = `${topHour}:00`;\n    }\n}\n\nconst sortedProducts = Object.entries(productCounts).sort((a, b) => b[1] - a[1]);\nconst top5List = sortedProducts.slice(0, 5).map(([name, qty]) => `• ${name}: <b>${qty}</b> قطعة`).join('<br>');\n\nreturn {\n    totalSales: totalRevenue.toLocaleString('en-US', { style: 'currency', currency: 'USD' }),\n    ordersCount: items.length,\n    topProduct: sortedProducts.length > 0 ? sortedProducts[0][0] : \"N/A\",\n    top5Products: top5List,\n    peakHour: peakResult,\n    insight: totalQty > 100 ? \"طلب مرتفع جداً، تأكد من المخزون.\" : \"أداؤك مستقر اليوم.\",\n    userEmail: $node[\"Receive Sales File\"].json.body.email \n};"
      },
